    "terminal.ansiBrightMagenta": "#FF84C8",
    "terminal.ansiBrightRed": "#FF7E92",
    "terminal.ansiBrightWhite": "#F2FBFF",
    "terminal.ansiBrightYellow": "#E6FF72",
    "terminal.ansiCyan": "#00C7A3",
    "terminal.ansiGreen": "#00C7A3",
    "terminal.ansiMagenta": "#FF5DB1",
    "terminal.ansiRed": "#FF5D7A",
    "terminal.ansiWhite": "#DFF5FF",
    "terminal.ansiYellow": "#D7FF3F",
    "terminal.background": "#0B1018",
    "terminal.foreground": "#DFF5FF",
    "terminalCursor.background": "#0B1018",
    "terminalCursor.foreground": "#D7FF3F",
    "textLink.activeForeground": "#8DEBFF",
    "textLink.foreground": "#35E0FF",
    "titleBar.activeBackground": "#0B1018",
    "titleBar.activeForeground": "#DFF5FF",
    "titleBar.border": "#1A2635",
    "titleBar.inactiveBackground": "#0B1018",
    "titleBar.inactiveForeground": "#8294A8",
    "tree.indentGuidesStroke": "#213242",
    "widget.shadow": "#00000066"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#5E6D81",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.modifier",
        "storage.type"
      ],
      "settings": {
        "foreground": "#D7FF3F"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "keyword.control.import",
        "keyword.control.from",
        "keyword.control.as"
      ],
      "settings": {
        "foreground": "#FF6F3C"
      }
    },
    {
      "scope": [
        "variable.language",
        "support.variable.magic",
        "support.variable",
        "variable.parameter.function.language.special"
      ],
      "settings": {
        "foreground": "#35E0FF"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter",
        "meta.function.parameters variable"
      ],
      "settings": {
        "foreground": "#FF9A6A"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable",
        "meta.definition.variable.name"
      ],
      "settings": {
        "foreground": "#DFF5FF"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#FF5DB1"
      }
    },
    {
      "scope": [
        "entity.name.method",
        "meta.method-call",
        "support.function.method"
      ],
      "settings": {
        "foreground": "#FF74BE"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.struct",
        "entity.name.enum",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#35E0FF"
      }
    },
    {
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "support.namespace"
      ],
      "settings": {
        "foreground": "#95A6FF"
      }
    },
    {
      "scope": [
        "constant",
        "constant.language",
        "constant.character.escape",
        "constant.numeric",
        "constant.character"
      ],
      "settings": {
        "foreground": "#35E0FF"
      }
    },
    {
      "scope": [
        "string",
        "meta.embedded.assembly string"
      ],
      "settings": {
        "foreground": "#FFB38E"
      }
    },
    {
      "scope": [
        "string.regexp",
        "constant.other.symbol",
        "constant.other.reference.link"
      ],
      "settings": {
        "foreground": "#95A6FF"
      }
    },
    {
      "scope": [
        "constant.other.color",
        "entity.other.attribute-name",
        "meta.object-literal.key",
        "support.type.property-name",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#00C7A3"
      }
    },
    {
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "punctuation.definition.decorator",
        "storage.type.annotation",
        "meta.annotation"
      ],
      "settings": {
        "foreground": "#FF6F3C"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#7F91A7"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#091019",
        "background": "#FF5D7A"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#D7FF3F",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#DFF5FF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic",
        "markup.quote"
      ],
      "settings": {
        "foreground": "#95A6FF",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw.block",
        "fenced_code.block"
      ],
      "settings": {
        "foreground": "#00C7A3"
      }
    },
    {
      "scope": [
        "markup.list",
        "punctuation.definition.list.begin.markdown"
      ],
      "settings": {
        "foreground": "#FF6F3C"
      }
    },
    {
      "scope": [
        "markup.link",
        "string.other.link.title",
        "string.other.link.description"
      ],
      "settings": {
        "foreground": "#35E0FF",
        "fontStyle": "underline"
      }
    },

    // Python-specific styles.
    {
      "scope": [
        "source.python keyword",
        "source.python storage.type"
      ],
      "settings": {
        "foreground": "#D7FF3F"
      }
    },
    {
      "scope": [
        "source.python support.type.exception",
        "source.python support.class",
        "source.python entity.name.type.class"
      ],
      "settings": {
        "foreground": "#35E0FF"
      }
    },
    {
      "scope": [
        "source.python entity.name.function",
        "source.python meta.function-call.generic",
        "source.python support.function.builtin"
      ],
      "settings": {
        "foreground": "#FF5DB1"
      }
    },
    {
      "scope": [
        "source.python variable.parameter",
        "source.python variable.parameter.function-call"
      ],
      "settings": {
        "foreground": "#FF9A6A"
      }
    },
    {
      "scope": [
        "source.python variable.language.special.self",
        "source.python variable.language.special.cls",
        "source.python constant.other.caps"
      ],
      "settings": {
        "foreground": "#35E0FF"
      }
    },
    {
      "scope": [
        "source.python meta.function.decorator",
        "source.python punctuation.definition.decorator"
      ],
      "settings": {
        "foreground": "#FF6F3C"
      }
    },
    {
      "scope": [
        "source.python string",
        "source.python punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#FFB38E"
      }
    },
    {
      "scope": [
        "source.python constant.numeric",
        "source.python constant.language"
      ],
      "settings": {
        "foreground": "#35E0FF"
      }
    },

    // Julia-specific styles.
    {
      "scope": [
        "source.julia keyword",
        "source.julia storage.type",
        "source.julia keyword.control"
      ],
      "settings": {
        "foreground": "#D7FF3F"
      }
    },
    {
      "scope": [
        "source.julia entity.name.function",
        "source.julia support.function",
        "source.julia meta.function-call"
      ],
      "settings": {
        "foreground": "#FF5DB1"
      }
    },
    {
      "scope": [
        "source.julia entity.name.type",
        "source.julia support.type",
        "source.julia support.class"
      ],
      "settings": {
        "foreground": "#35E0FF"
      }
    },
    {
      "scope": [
        "source.julia variable.parameter",
        "source.julia meta.parameters variable"
      ],
      "settings": {
        "foreground": "#FF9A6A"
      }
    },
    {
      "scope": [
        "source.julia meta.macro",
        "source.julia entity.name.function.macro",
        "source.julia punctuation.definition.macro"
      ],
      "settings": {
        "foreground": "#FF6F3C"
      }
    },
    {
      "scope": [
        "source.julia constant.numeric",
        "source.julia constant.language",
        "source.julia constant.character"
      ],
      "settings": {
        "foreground": "#35E0FF"
      }
    },
    {
      "scope": [
        "source.julia string"
      ],
      "settings": {
        "foreground": "#FFB38E"
      }
    }
  ]
}
